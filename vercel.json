{
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/setup-market.js": {
      "includeFiles": "supabase/market.sql"
    }
  },
  "rewrites": [
    {
      "source": "/config/colecao-figurinhas",
      "destination": "/config/colecao-figurinhas/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
